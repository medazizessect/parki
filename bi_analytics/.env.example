# =============================================================
# Parki BI Analytics – Environment Variables
# =============================================================

# MySQL Datamart
BI_MYSQL_HOST=localhost
BI_MYSQL_PORT=3306
BI_MYSQL_USER=parki
BI_MYSQL_PASSWORD=change_me_in_production
BI_MYSQL_DATABASE=parki_datamart
BI_MYSQL_POOL_NAME=parki_pool
BI_MYSQL_POOL_SIZE=5

# Grafana
BI_GRAFANA_HOST=localhost
BI_GRAFANA_PORT=3000
BI_GRAFANA_ADMIN_USER=admin
BI_GRAFANA_ADMIN_PASSWORD=change_me_in_production

# API
BI_API_HOST=0.0.0.0
BI_API_PORT=8000
BI_API_DEBUG=false
BI_API_CORS_ORIGINS=*

# Map
BI_MAP_CENTER_LAT=-23.5505
BI_MAP_CENTER_LNG=-46.6333
BI_MAP_ZOOM=12
BI_MAP_TILE_PROVIDER=OpenStreetMap
BI_MAP_OUTPUT_DIR=./maps
