# ==============================================================
# Parki Capture Reconnaissance — Environment Configuration
# ==============================================================
# Copy this file to .env and fill in the actual values.
# ==============================================================

# ---- MySQL ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=parki
MYSQL_PASSWORD=change_me_in_production
MYSQL_DATABASE=parki_capture
MYSQL_POOL_SIZE=5

# ---- Cameras ----
# Comma-separated list of RTSP URLs (used when cameras.yaml is not provided)
CAMERA_RTSP_URLS=rtsp://admin:password@192.168.1.101:554/stream1,rtsp://admin:password@192.168.1.102:554/stream1
CAMERA_RESOLUTION_WIDTH=1280
CAMERA_RESOLUTION_HEIGHT=720
CAMERA_FPS=15

# ---- YOLO ----
YOLO_MODEL_PATH=yolov8s.pt
YOLO_CONFIDENCE_THRESHOLD=0.4
YOLO_DEVICE=cpu

# ---- Airflow ----
AIRFLOW_DAG_SCHEDULE_CAPTURE=*/5 * * * *
AIRFLOW_DAG_SCHEDULE_ETL=0 * * * *
AIRFLOW_DATA_RETENTION_DAYS=30

# ---- Logging ----
LOG_LEVEL=INFO
